{
  "__comment": "Dashboard Grafana — ADV Backend Spring Boot",
  "__note": "Importer ce fichier dans Grafana : Dashboards → Import → Upload JSON",
  "__alternative": "Utiliser le dashboard officiel Spring Boot : ID 12900 sur grafana.com",
  "id": null,
  "uid": "adv-backend-overview",
  "title": "ADV — Backend Spring Boot",
  "tags": ["adv", "spring-boot", "backend"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "API — Requêtes par seconde",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{
        "expr": "rate(http_server_requests_seconds_count{job='adv-backend'}[1m])",
        "legendFormat": "req/s"
      }]
    },
    {
      "id": 2,
      "title": "API — Temps de réponse p95",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job='adv-backend'}[5m]))",
        "legendFormat": "p95 (s)"
      }]
    },
    {
      "id": 3,
      "title": "JVM — Heap utilisée",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{
        "expr": "jvm_memory_used_bytes{area='heap',job='adv-backend'} / jvm_memory_max_bytes{area='heap',job='adv-backend'} * 100",
        "legendFormat": "Heap %"
      }],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 100, "unit": "percent",
          "thresholds": { "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 85 }
          ]}
        }
      }
    },
    {
      "id": 4,
      "title": "API — Taux d'erreurs 5xx",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{
        "expr": "rate(http_server_requests_seconds_count{job='adv-backend',status=~'5..'}[5m])",
        "legendFormat": "erreurs/s"
      }]
    }
  ]
}