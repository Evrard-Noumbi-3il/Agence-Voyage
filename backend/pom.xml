<build>
  <plugins>

    <!-- ─────────────────────────────────────────────────────────────────── -->
    <!-- CHECKSTYLE — Lint Java                                              -->
    <!-- ─────────────────────────────────────────────────────────────────── -->
    <plugin>
      <groupId>org.apache.maven.plugins</groupId>
      <artifactId>maven-checkstyle-plugin</artifactId>
      <version>3.4.0</version>
      <configuration>
        <configLocation>checkstyle.xml</configLocation>
        <consoleOutput>true</consoleOutput>
        <failsOnError>true</failsOnError>
        <includeTestSourceDirectory>false</includeTestSourceDirectory>
      </configuration>
      <executions>
        <execution>
          <id>checkstyle</id>
          <phase>validate</phase>
          <goals>
            <goal>check</goal>
          </goals>
        </execution>
      </executions>
    </plugin>

    <!-- ─────────────────────────────────────────────────────────────────── -->
    <!-- SUREFIRE — Tests unitaires JUnit 5                                  -->
    <!-- ─────────────────────────────────────────────────────────────────── -->
    <plugin>
      <groupId>org.apache.maven.plugins</groupId>
      <artifactId>maven-surefire-plugin</artifactId>
      <version>3.3.1</version>
      <configuration>
        <excludes>
          <!-- Exclure les tests d'intégration du run unitaire -->
          <exclude>**/*IntegrationTest.java</exclude>
          <exclude>**/*IT.java</exclude>
        </excludes>
      </configuration>
    </plugin>

    <!-- ─────────────────────────────────────────────────────────────────── -->
    <!-- JACOCO — Code Coverage                                              -->
    <!-- ─────────────────────────────────────────────────────────────────── -->
    <plugin>
      <groupId>org.jacoco</groupId>
      <artifactId>jacoco-maven-plugin</artifactId>
      <version>0.8.12</version>
      <executions>
        <execution>
          <id>prepare-agent</id>
          <goals>
            <goal>prepare-agent</goal>
          </goals>
        </execution>
        <execution>
          <id>report</id>
          <phase>test</phase>
          <goals>
            <goal>report</goal>
          </goals>
        </execution>
        <execution>
          <!-- Bloquer si coverage < 70% sur les services critiques -->
          <id>check</id>
          <goals>
            <goal>check</goal>
          </goals>
          <configuration>
            <rules>
              <rule>
                <element>PACKAGE</element>
                <includes>
                  <include>com.adv.modules.booking.*</include>
                  <include>com.adv.modules.payment.*</include>
                  <include>com.adv.modules.iam.*</include>
                </includes>
                <limits>
                  <limit>
                    <counter>LINE</counter>
                    <value>COVEREDRATIO</value>
                    <minimum>0.70</minimum>
                  </limit>
                </limits>
              </rule>
            </rules>
          </configuration>
        </execution>
      </executions>
    </plugin>

    <!-- ─────────────────────────────────────────────────────────────────── -->
    <!-- SONAR — SAST (déclenché par mvn sonar:sonar dans CI)               -->
    <!-- ─────────────────────────────────────────────────────────────────── -->
    <plugin>
      <groupId>org.sonarsource.scanner.maven</groupId>
      <artifactId>sonar-maven-plugin</artifactId>
      <version>4.0.0.4121</version>
    </plugin>

  </plugins>
</build>

<!--
  Profile "coverage" : activer JaCoCo uniquement dans le CI
  Usage : mvn test -Pcoverage
-->
<profiles>
  <profile>
    <id>coverage</id>
    <build>
      <plugins>
        <plugin>
          <groupId>org.jacoco</groupId>
          <artifactId>jacoco-maven-plugin</artifactId>
          <executions>
            <execution>
              <id>prepare-agent</id>
              <goals><goal>prepare-agent</goal></goals>
            </execution>
            <execution>
              <id>report</id>
              <phase>test</phase>
              <goals><goal>report</goal></goals>
            </execution>
          </executions>
        </plugin>
      </plugins>
    </build>
  </profile>
</profiles>

<properties>
    <java.version>21</java.version>
    <sonar.organization>evrard-noumbi-3il</sonar.organization>
    <sonar.host.url>https://sonarcloud.io</sonar.host.url>
    <sonar.coverage.jacoco.xmlReportPaths>target/site/jacoco/jacoco.xml</sonar.coverage.jacoco.xmlReportPaths>
    <sonar.exclusions>**/dto/**, **/entity/**, **/config/**</sonar.exclusions>
</properties>